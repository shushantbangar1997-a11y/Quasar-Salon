{
  "expo": {
    "name": "Quasar Salon",
    "slug": "quasar-salon",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "newArchEnabled": false,
    "scheme": "quasarsalon",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/quasar-logo-transparent.png",
    "splash": {
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain",
      "image": "./assets/quasar-logo-transparent.png"
    },
    "ios": {
      "bundleIdentifier": "com.quasarsalon.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Quasar Salon needs access to your photos so admins can upload staff profile photos.",
        "NSCameraUsageDescription": "Quasar Salon needs access to your camera so admins can take staff profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.quasarsalon.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/quasar-logo-transparent.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": ["READ_EXTERNAL_STORAGE", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/quasar-logo-transparent.png"
    },
    "plugins": ["expo-image-picker"]
  }
}
