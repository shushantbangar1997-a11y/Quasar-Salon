{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx expo export --platform web --output-dir dist"
  },
  "deploy": {
    "startCommand": "npx serve dist --listen $PORT --no-clipboard",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
