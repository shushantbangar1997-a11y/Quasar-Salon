modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "backend-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && EXPO_PUBLIC_API_BASE_URL=\"https://$REPLIT_DEV_DOMAIN\" npx expo start --web --port 5000 --tunnel"
waitForPort = 5000

[[workflows.workflow]]
name = "backend-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend/functions && npx tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "mobile-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && npx tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PORT=8080 node functions/lib/server.js"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "static"
build = ["sh", "-c", "cd mobile && npx expo export --platform web --output-dir dist"]
publicDir = "mobile/dist"

[userenv]

[userenv.shared]
EXPO_PUBLIC_FIREBASE_API_KEY = "AIzaSyA0NYDMWhuxDiFkbncYd3K-3n-a7129rW0"
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN = "quasar-salon.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID = "quasar-salon"
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET = "quasar-salon.firebasestorage.app"
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "970869144881"
EXPO_PUBLIC_FIREBASE_APP_ID = "1:970869144881:web:9d51e608656c3e574c8410"
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID = "G-14Y4X76C8X"
GCLOUD_PROJECT = "quasar-salon"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
